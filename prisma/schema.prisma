generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  role          String          @default("user")
  accounts      Account[]
  sessions      Session[]
  // Optional for WebAuthn support
  Authenticator Authenticator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// Optional for WebAuthn support
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

// 換匯紀錄表
model ExchangeRecord {
  id          Int      @id @default(autoincrement())
  twdSpent    Float
  thbReceived Float
  createdAt   DateTime @default(now())
}

// 庫存商品表
model InventoryItem {
  id              Int            @id @default(autoincrement())
  brand           String // 品牌
  name            String // 品名
  style           String // 款式
  size            String // 尺寸
  foreignCost     Float
  appliedRate     Float
  twdCost         Int
  quantity        Int // 現有庫存數量
  stockQuantity   Int            @default(0) // 進貨數量
  /// 狀態 Enum: 1 = 已下單, 2 = 已到貨(TH), 3 = 已出貨(TH), 4 = 已到貨(TW)
  status          Int            @default(1)
  /// 扣款方式: cash = 現金, card = 刷卡
  paymentMethod   String         @default("cash")
  purchaseOrderId Int?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  orderItems      OrderItem[]
}

// 訂單表
model Order {
  id           String      @id
  customerName String // 姓名
  storeNumber  String? // 店號
  storeName    String? // 店名
  transferCode String? // 匯款後五碼
  totalAmount  Int // 金額
  note         String? // 備註
  detail       String? // 訂單明細
  lineName     String? // Line名字
  email        String? // Email
  status       String      @default("placed")
  isDeducted   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrderItem[]
}

// 訂單明細表
model OrderItem {
  id              Int            @id @default(autoincrement())
  orderId         String
  brand           String? // 品牌
  name            String? // 品名
  style           String? // 款式
  size            String? // 尺寸
  sellPriceTwd    Int // 單價 (TWD)
  quantity        Int            @default(1)
  inventoryItemId Int?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// 採購單表
model PurchaseOrder {
  id             Int             @id @default(autoincrement())
  orderNumber    String?         @unique @default(uuid()) // 單號
  orderedBy      String          @default("WangNa") // 下單人
  brand          String // 品牌
  name           String // 品名
  style          String // 款式
  size           String // 尺寸
  quantity       Int             @default(1) // 數量
  link           String // 連結
  note           String? // 備註 (選填)
  /// 狀態 Enum: 1 = 已下單, 2 = 已到貨(TH), 3 = 已出貨(TH), 4 = 已到貨(TW)
  status         Int             @default(0) // 狀態
  inventoryItems InventoryItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

// 運費與雜支表
model Expense {
  id            Int      @id @default(autoincrement())
  type          String // 類型 (shipping: 運費, misc: 雜支)
  title         String // 標題（例如：1月海運費、封箱膠帶）
  amountThb     Float // 泰銖金額
  amountTwd     Int // 台幣成本
  appliedRate   Float // 套用的匯率
  paymentMethod String   @default("cash") // 扣款方式: cash = 現金, card = 刷卡
  date          DateTime // 支出日期
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
